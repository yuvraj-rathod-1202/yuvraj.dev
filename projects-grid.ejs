::: {.list .grid .quarto-listing-cols-3}

<% for (const item of items) { %>

::: {.g-col-1}

```{=html}
<a href="<%- item.path %>" class="quarto-grid-link">
<div class="quarto-grid-item card h-100 card-left">
```

::: {.card-body .post-contents}

<% if (item.title) { %>
<h5 class="no-anchor card-title listing-title"><%= item.title %></h5>
<% } %>

<% // GitHub and Live Demo links on the card %>
<% if (item.github || item['live-demo']) { %>
```{=html}
<div class="card-project-links delink">
  <% if (item.github) { %>
  <span class="card-project-link" onclick="window.open('<%= item.github %>', '_blank'); event.preventDefault(); event.stopPropagation();">GitHub</span>
  <% } %>
  <% if (item.github && item['live-demo']) { %>
  <span class="card-project-link-separator">|</span>
  <% } %>
  <% if (item['live-demo']) { %>
  <span class="card-project-link" onclick="window.open('<%= item['live-demo'] %>', '_blank'); event.preventDefault(); event.stopPropagation();">Live Demo</span>
  <% } %>
</div>
```
<% } %>

<% if (item.categories) { %>
```{=html}
<div class="listing-categories">
<% for (const category of item.categories) { %>
<div class="listing-category" onclick="window.quartoListingCategory('<%= utils.b64encode(category) %>'); return false;"><%= category %></div>
<% } %>
</div>
```
<% } %>

<% if (item.description) { %>
```{=html}
<div class="card-text listing-description delink">
```
<%= item.description %>
```{=html}
</div>
```
<% } %>

<% // Project Duration in the date slot %>
<% if (item.subtitle) { %>
```{=html}
<div class="card-attribution card-text-small end">
<div class="listing-date"><%= item.subtitle %></div>
</div>
```
<% } %>

:::

```{=html}
</div></a>
```

:::

<% } %>

:::
